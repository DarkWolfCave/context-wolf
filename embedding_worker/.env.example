# ContextWolf Embedding Worker - Database Connection
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Note: The embedding worker reads from ~/.context/config.yaml by default.
# This .env file is only needed if you want to override those settings.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=context_manager
POSTGRES_USER=cm_user
POSTGRES_PASSWORD=changeme
