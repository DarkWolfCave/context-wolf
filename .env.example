# ContextWolf - Environment Configuration
# Copy this file to .env and adjust values. .env is gitignored.

# ===========================================
# DATABASE (required)
# ===========================================
POSTGRES_USER=cm_user
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=context_manager

# Host port for external clients (CLI, MCP server, GUI backend)
# 5432 = standard PostgreSQL port
# Change this only if another PostgreSQL instance already uses 5432
POSTGRES_PORT=5432

# Timezone inside the database container
TZ=Europe/Berlin

# NOTE: Do not set PGDATA. PG18 manages its own subdirectory layout inside
# /var/lib/postgresql. See docker-compose.yml comments for details.
